generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Operator {
  id              String    @id @default(cuid())
  name            String    @unique
  domain          String?
  priority        Int?      @default(1)
  cooldownSeconds Int?      @default(60)
  lastRunAt       DateTime?

  // Reverse relations
  memories              Memory[]
  tasks                 Task[]
  autonomyGoals         AutonomyGoal[]
  logs                  LogEntry[]
  reasoningCacheEntries ReasoningCacheEntry[]
  compiledPatterns      CompiledPattern[]
  knowledgeEntries      KnowledgeEntry[]
  projects              Project[]
  goals                 Goal[]
  habits                Habit[]
  notes                 Note[]
  dailyPlans            DailyPlan[]
  calendarEvents        CalendarEvent[]
  bridgeSignals         BridgeSignal[]
  corpusDocuments       CorpusDocument[]
}

model Memory {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])
  category   String
  value      String
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Extended in place from the Phase-0 stub (data-preserving: legacy rows keep
// operatorId/title/status/metadata and pick up defaults for the new fields).
// operatorId is nullable — personal tasks ("call mom") have no operator lens.
model Task {
  id               String    @id @default(cuid())
  operatorId       String?
  operator         Operator? @relation(fields: [operatorId], references: [id])
  projectId        String?
  project          Project?  @relation(fields: [projectId], references: [id])
  goalId           String?
  goal             Goal?     @relation(fields: [goalId], references: [id])
  domain           String    @default("personal")
  title            String
  description      String?
  status           String // "inbox" | "today" | "next" | "later" | "waiting" | "done" | "abandoned" (legacy rows keep their strings)
  priority         String    @default("normal") // "critical" | "high" | "normal" | "low"
  estimatedMinutes Int?
  actualMinutes    Int?
  dueDate          DateTime?
  scheduledFor     DateTime? // when Cole plans to do it
  completedAt      DateTime?
  origin           String    @default("cole") // "cole" | "aurelius_proposed" | "ritual_generated"
  originContext    Json? // for proposed tasks: why Aurelius suggested it
  metadata         Json? // legacy field, preserved
  parentTaskId     String?
  parent           Task?     @relation("SubTasks", fields: [parentTaskId], references: [id])
  subtasks         Task[]    @relation("SubTasks")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([operatorId, status])
  @@index([status, scheduledFor])
  @@index([status, dueDate])
}

model AutonomyGoal {
  id          String   @id @default(cuid())
  operatorId  String
  operator    Operator @relation(fields: [operatorId], references: [id])
  description String
  status      String
  priority    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LogEntry {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])
  type       String
  level      String
  message    String
  context    Json?
  createdAt  DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 4.5 — COMPILED UNDERSTANDING
// Two tables that turn Aurelius's experience into reusable knowledge.
// ReasoningCacheEntry stores tagged situations + prior conclusions.
// CompiledPattern stores patterns derived across similar situations.
// ═══════════════════════════════════════════════════════════════════

model ReasoningCacheEntry {
  id                 String   @id @default(cuid())
  operatorId         String
  operator           Operator @relation(fields: [operatorId], references: [id])

  // Modularity primitive: operator + domain as separate axes
  domain             String   @default("training_session")

  // Identity / scope — generalized for cross-operator use
  entityKey          String   // athlete name, lead ID, post ID, etc.
  externalScopeId    String   // sheet ID, CRM ID, post ID — was sheetId
  subContext         String?  // "Day 1", "Q4_2026", "instagram_reels" — was dayTab

  // The situation, tagged at write time using the operator's knowledge module
  situationSignature Json

  // What Aurelius concluded for this situation
  reasoningSummary   String

  // Provenance + usage
  sourceMemoryIds    String[]
  usageCount         Int      @default(0)

  // Re-tagging support (populated in future; v1 leaves empty)
  previousTags       Json[]   @default([])

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([operatorId, domain, entityKey])
  @@index([operatorId, entityKey, externalScopeId])
  @@index([domain])
}

model CompiledPattern {
  id                 String   @id @default(cuid())
  operatorId         String
  operator           Operator @relation(fields: [operatorId], references: [id])

  // Modularity primitive (matches ReasoningCacheEntry)
  domain             String

  // Scope — null entityKey = cross-entity (e.g., cross-athlete)
  entityKey          String?
  externalScopeId    String?

  // Pattern shape
  patternType        String   // "factual" | "heuristic" | "structuralMatch"
  patternSignature   Json
  conditions         Json?

  // Lifecycle status
  // auto_factual          — facts that compiled automatically (N=2)
  // proposed_heuristic    — heuristic noticed but unconfirmed (N=3)
  // confirmed_heuristic   — Cole confirmed; usable as soft rule
  // discarded             — Cole denied, kept as observation only
  status             String   @default("proposed_heuristic")

  // Evidence trail
  evidence           String[]
  supportCount       Int      @default(0)
  confidenceScore    Float    @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([operatorId, domain, entityKey])
  @@index([operatorId, status])
  @@index([domain])
}

// ═══════════════════════════════════════════════════════════════════
// PRODUCTIVITY PLANE — Cole's lane
// The whole-life second-brain entities: what Cole is executing, distinct
// from what Aurelius is doing in the background. operatorId is nullable
// throughout — personal items have no operator lens. AutonomyGoal (above)
// stays Aurelius's objectives; Goal here is Cole's. Consolidation of the
// two is deferred to the autonomy-engine rebuild, which owns that code.
// BridgeSignal is where the two lanes meet.
// ═══════════════════════════════════════════════════════════════════

model Project {
  id          String    @id @default(cuid())
  operatorId  String?
  operator    Operator? @relation(fields: [operatorId], references: [id])
  domain      String    @default("personal") // "coaching_business" | "coaching_platform" | "school" | "finance" | "content" | "personal" | "cole_training"
  name        String
  description String?
  status      String    @default("active") // "active" | "paused" | "shipped" | "abandoned"
  priority    String    @default("normal") // "critical" | "high" | "normal" | "backburner"
  targetDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  goals Goal[]
  tasks Task[]

  @@index([status, priority])
  @@index([domain, status])
}

model Goal {
  id          String    @id @default(cuid())
  operatorId  String?
  operator    Operator? @relation(fields: [operatorId], references: [id])
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  domain      String    @default("personal")
  name        String
  description String?
  measure     Json? // { type: "count" | "boolean" | "value" | "date_hit", target, current }
  horizon     String    @default("quarter") // "quarter" | "year" | "life"
  status      String    @default("active") // "active" | "hit" | "missed" | "revised"
  targetDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tasks Task[]

  @@index([status, horizon])
}

model Habit {
  id             String    @id @default(cuid())
  operatorId     String?
  operator       Operator? @relation(fields: [operatorId], references: [id])
  domain         String    @default("personal")
  name           String
  cadence        String    @default("daily") // "daily" | "weekly" | "custom_cron"
  cronExpression String?
  active         Boolean   @default(true)
  streak         Int       @default(0)
  longestStreak  Int       @default(0)
  createdAt      DateTime  @default(now())

  completions HabitCompletion[]

  @@index([active])
}

model HabitCompletion {
  id          String   @id @default(cuid())
  habitId     String
  habit       Habit    @relation(fields: [habitId], references: [id])
  completedAt DateTime @default(now())
  note        String?

  @@index([habitId, completedAt])
}

model Note {
  id               String    @id @default(cuid())
  operatorId       String?
  operator         Operator? @relation(fields: [operatorId], references: [id])
  domain           String    @default("personal")
  title            String?
  content          String // markdown
  captureContext   String? // "quick_capture" | "meeting" | "reading" | "voice"
  linkedTaskIds    String[]
  linkedProjectIds String[]
  linkedMemoryIds  String[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([createdAt])
}

model DailyPlan {
  id          String    @id @default(cuid())
  date        DateTime  @unique // day this plan is for (midnight UTC)
  operatorId  String?
  operator    Operator? @relation(fields: [operatorId], references: [id])
  generatedBy String    @default("cole_manual") // "morning_briefing" | "cole_manual" | "revised"
  headline    String? // briefing summary sentence
  focus       String? // 1-3 sentences: what today is about
  taskIds     String[] // ordered Task.id list for today
  ritualIds   String[] // linked RitualInstance ids
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Ritual {
  id            String   @id @default(cuid())
  name          String   @unique // "morning_briefing" | "nightly_debrief" | "weekly_planning" | "midday_check"
  cadence       String // "daily_morning" | "daily_night" | "weekly_sunday" | "on_demand"
  scheduledTime String // "07:00" | "21:30" | "sunday_09:00"
  active        Boolean  @default(true)
  templateJson  Json?
  createdAt     DateTime @default(now())

  instances RitualInstance[]
}

model RitualInstance {
  id               String    @id @default(cuid())
  ritualId         String
  ritual           Ritual    @relation(fields: [ritualId], references: [id])
  scheduledFor     DateTime
  firedAt          DateTime?
  status           String    @default("scheduled") // "scheduled" | "generated" | "delivered" | "acknowledged" | "skipped" | "revoked"
  outputText       String?
  outputStructured Json?
  deliveredVia     String? // "push" | "in_app" | "email"
  acknowledgedAt   DateTime?
  createdAt        DateTime  @default(now())

  @@index([ritualId, scheduledFor])
  @@index([status, scheduledFor])
}

model CalendarEvent {
  id            String    @id @default(cuid())
  externalId    String    @unique // Google event id
  operatorId    String?
  operator      Operator? @relation(fields: [operatorId], references: [id])
  domain        String    @default("personal")
  title         String
  description   String?
  startAt       DateTime
  endAt         DateTime
  location      String?
  attendees     Json?
  linkedTaskIds String[]
  syncedAt      DateTime  @default(now())
  raw           Json?

  @@index([startAt])
}

// The core two-lane surface. Aurelius's background work surfaces here;
// Cole's steering writes here too (kind="cole_steer").
model BridgeSignal {
  id         String    @id @default(cuid())
  kind       String // "background_result" | "cole_steer" | "gap_alert" | "proposal_batch" | "opportunity" | "risk"
  operatorId String?
  operator   Operator? @relation(fields: [operatorId], references: [id])
  domain     String?
  sourceType String // "research_ingestion" | "compiled_pattern" | "reasoning_output" | "cole_message" | "ritual"
  sourceId   String?
  severity   String    @default("info") // "info" | "notice" | "attention" | "critical"
  title      String
  body       String // markdown
  actions    Json? // [{ label, action, payload }]
  status     String    @default("pending") // "pending" | "surfaced" | "acknowledged" | "acted" | "dismissed" | "expired"
  surfacedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([status, createdAt])
  @@index([kind, status])
}

// The push foundation: what Cole said mattered vs what actually happened.
model IntentActionGap {
  id          String   @id @default(cuid())
  goalId      String?
  projectId   String?
  domain      String
  windowStart DateTime
  windowEnd   DateTime
  intent      String
  action      String
  gapScore    Float // 0.0 = perfect alignment, 1.0 = complete miss
  gapSummary  String
  computedAt  DateTime @default(now())

  @@index([domain, computedAt])
}

// ═══════════════════════════════════════════════════════════════════
// SECOND BRAIN — CORPUS + MEASUREMENT
// CorpusDocument: everything ingested, registered so Aurelius is AWARE
// of what it knows (inventory injects into every prompt). Correction /
// MeasurementSnapshot / IngestionRun: the scoreboard + decay substrate.
// ═══════════════════════════════════════════════════════════════════

model CorpusDocument {
  id          String    @id @default(cuid())
  title       String
  sourceType  String    @default("note") // "upload" | "url" | "note" | "research"
  sourceUrl   String?
  domain      String    @default("personal")
  operatorId  String?
  operator    Operator? @relation(fields: [operatorId], references: [id])
  summary     String // short synopsis — what Aurelius "remembers" about it
  contentText String // full extracted text
  chunkCount  Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([domain, createdAt])
  @@index([createdAt])
}

model Correction {
  id             String   @id @default(cuid())
  operatorId     String?
  targetType     String // "compiled_pattern" | "knowledge_entry" | "reasoning_output"
  targetId       String
  correctionType String // "value_wrong" | "pattern_wrong" | "context_wrong" | "should_have_asked"
  before         Json?
  after          Json?
  reason         String?
  createdAt      DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}

model MeasurementSnapshot {
  id         String   @id @default(cuid())
  weekStart  DateTime
  operatorId String?
  metrics    Json // { llmDependenceRate, patternHitRate, correctionRate, coverage, gapAlignment, ... }
  createdAt  DateTime @default(now())

  @@unique([weekStart, operatorId])
}

model IngestionRun {
  id               String    @id @default(cuid())
  runType          String // "weekend_deep" | "targeted_gap" | "ad_hoc" | "corpus_upload"
  operatorName     String?
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  status           String    @default("running") // "running" | "completed" | "failed"
  sourcesQueried   Json?
  findingsCount    Int       @default(0)
  proposalsCreated Int       @default(0)
  errors           Json?
  triggeredBy      String    @default("schedule") // "schedule" | "cole" | "self_directed"

  @@index([startedAt])
}

// ═══════════════════════════════════════════════════════════════════
// MISSIONS — the autonomy loop that actually executes.
// Cole (or a schedule) states an objective; Aurelius plans discrete
// steps, runs them (research / recall / synthesize), and files a
// report. Reports auto-ingest into the corpus, so the second brain
// grows from its own missions. Hard rule carried: missions produce
// signals and proposals only — they never touch Living Knowledge
// directly and never act outward without Cole.
// ═══════════════════════════════════════════════════════════════════

model Mission {
  id           String    @id @default(cuid())
  title        String
  objective    String // what success looks like, in Cole's words
  domain       String    @default("personal")
  operatorName String? // lens the mission runs under (strategy default)
  origin       String    @default("cole") // "cole" | "aurelius_proposed" | "schedule"
  priority     String    @default("normal") // "low" | "normal" | "high"
  status       String    @default("proposed") // "proposed" | "planned" | "running" | "completed" | "failed" | "cancelled"
  planSummary  String? // one-line restatement of the approach
  report       String? // final report (markdown)
  corpusDocId  String? // report's home in the second brain
  error        String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  steps MissionStep[]

  @@index([status, createdAt])
}

model MissionStep {
  id         String    @id @default(cuid())
  missionId  String
  mission    Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  idx        Int
  kind       String // "research" | "recall" | "synthesize"
  input      String // query / instruction for this step
  status     String    @default("pending") // "pending" | "running" | "done" | "failed"
  output     String? // step result (truncated for storage)
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([missionId, idx])
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 4.6 — RETRIEVAL SUBSTRATE
// Derived data: semantic index over knowledge, memory, and reasoning.
// Rebuildable at any time from source tables (scripts/backfillEmbeddings).
// The embedding column is pgvector; Prisma treats it as Unsupported, so
// all reads/writes go through raw SQL in aurelius/retrieval/vectorStore.ts.
// Dimension fixed at 1536 (OpenAI text-embedding-3-small). Switching
// embedding models = migration + re-run backfill; cheap by design.
// ═══════════════════════════════════════════════════════════════════

model VectorEmbedding {
  id             String                       @id @default(cuid())
  sourceType     String // "knowledge_entry" | "memory" | "reasoning_cache" | "note" | "corpus_doc"
  sourceId       String
  chunkIndex     Int                          @default(0)
  chunkText      String // the text that was embedded (hydration + citation)
  operatorId     String? // loose reference — embeddings are derived, no FK
  domain         String?
  embedding      Unsupported("vector(1536)")?
  embeddingModel String
  createdAt      DateTime                     @default(now())

  @@unique([sourceType, sourceId, chunkIndex])
  @@index([sourceType, sourceId])
  @@index([operatorId])
}

// ═══════════════════════════════════════════════════════════════════
// PHASE 4.5a — LIVING KNOWLEDGE
// Structured, evolving domain intelligence. Updated by Cole's
// confirmed conversations and research ingestion. Provenance on
// every entry. Per-operator namespacing on a single table.
// ═══════════════════════════════════════════════════════════════════

model KnowledgeEntry {
  id          String   @id @default(cuid())
  operatorId  String
  operator    Operator @relation(fields: [operatorId], references: [id])

  // Scope — namespacing within an operator's knowledge
  // e.g., scope="rep_bands", key="strength" → value={lower:4, upper:5, intent:"strength"}
  scope       String   // top-level category: "rep_bands", "intensity_zones", etc.
  key         String   // identifier within scope: "strength", "hypertrophy", etc.
  value       Json     // the actual knowledge payload (structured)

  // Provenance — why does this value exist?
  // sourceType: "founding_default" | "cole_conversation" | "research_ingestion" | "manual"
  // sourceId: opaque reference (memory id, research result id, conversation turn id)
  // rationale: short human-readable explanation
  sourceType  String
  sourceId    String?
  rationale   String?

  // Audit + lifecycle
  createdBy   String   // "system" for seeded defaults, "cole" for confirmed updates, etc.
  updatedBy   String?
  version     Int      @default(1)  // increments on update
  active      Boolean  @default(true) // soft-disable without deletion

  // History trail — previous values preserved for audit
  // Each prior version stored as { value, sourceType, sourceId, rationale, version, replacedAt }
  history     Json[]   @default([])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([operatorId, scope, key])
  @@index([operatorId, scope])
  @@index([operatorId, active])
}