# AURELIUS — environment template. Copy to .env and fill in.
# .env is gitignored; NEVER commit real values. In Codespaces, secrets set
# at github.com/settings/codespaces OVERRIDE .env (dotenv does not overwrite
# existing env vars) — a changed secret needs a full codespace stop/restart.

# ── Database (required) ──────────────────────────────────────────────
# Local sandbox: postgresql://aurelius:aurelius@127.0.0.1:5432/aurelius
# Production: the Neon URL (or the Mini's local Postgres after deploy)
DATABASE_URL=

# ── LLM providers (Anthropic at minimum; router degrades gracefully) ─
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=

# ── Embeddings ───────────────────────────────────────────────────────
# "gemini" in production · "mock" for keyless local dev
EMBEDDINGS_PROVIDER=gemini

# ── Telegram bridge (dormant until both are set) ─────────────────────
# Token from @BotFather — the FULL value, digits:letters, no quotes.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google Calendar (dormant until both are set) ─────────────────────
# Desktop-app OAuth client from console.cloud.google.com.
# One-time authorize at /api/calendar/auth after boot.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override; defaults to http://localhost:<PORT>/api/calendar/callback
# GOOGLE_REDIRECT_URI=

# ── Google Sheets (training engine) ──────────────────────────────────
GOOGLE_SHEETS_SERVICE_ACCOUNT_PATH=

# ── Second-brain bridges (dormant until set — Mini deploy step) ──────
# PAPERLESS_URL=
# PAPERLESS_TOKEN=
# Obsidian vault mirror directory:
# VAULT_DIR=

# ── Optional research keys (Tier 1.5 academic sources need none) ─────
# SERPAPI_KEY=
# BING_API_KEY=

# ── Server ───────────────────────────────────────────────────────────
PORT=3001
